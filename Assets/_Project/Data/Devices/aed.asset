  description: "\uC2EC\uC815\uC9C0 \uC758\uC2EC \uD658\uC790\uC5D0\uAC8C \uC0AC\uC6A9\uD558\uB294
    \uC790\uB3D9\uC2EC\uC7A5\uCDA9\uACA9\uAE30\uC785\uB2C8\uB2E4."
  locationText: "\uC5ED\uBB34\uC2E4 \uADFC\uCC98\uC640 \uC2B9\uAC15\uC7A5 \uC548\uB0B4

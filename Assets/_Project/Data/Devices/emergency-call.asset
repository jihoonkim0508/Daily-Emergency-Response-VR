  id: emergency-call
  displayName: "\uBE44\uC0C1\uD1B5\uD654\uC7A5\uCE58"
  zoneType: 0
  deviceType: 0
  description: "\uC5ED\uBB34\uC6D0 \uB610\uB294 \uAD00\uC81C\uC13C\uD130\uC640 \uC5F0\uACB0\uD574
    \uC0C1\uD669\uC744 \uC54C\uB9AC\uB294 \uC7A5\uCE58\uC785\uB2C8\uB2E4."
  locationText: "\uC2B9\uAC15\uC7A5 \uAE30\uB465\uACFC \uB300\uD569\uC2E4 \uBCBD\uBA74"
  useSituation: "\uD658\uC790 \uBC1C\uC0DD, \uC0AC\uACE0 \uBAA9\uACA9, \uC5F4\uCC28
    \uB0B4 \uBE44\uC0C1 \uC0C1\uD669"
  useMethod: "\uCEE4\uBC84\uB97C \uD655\uC778\uD558\uACE0 \uD638\uCD9C \uBC84\uD2BC\uC744
    \uB20C\uB7EC \uC704\uCE58\uC640 \uC0C1\uD669\uC744 \uB9D0\uD569\uB2C8\uB2E4."
  requiredInteractionType: 4
  successMessage: "\uAD00\uC81C \uC5F0\uACB0 \uD655\uC778 \uC644\uB8CC. \uC704\uCE58\uC640
    \uC0C1\uD669\uC744 \uB610\uB837\uD558\uAC8C \uC804\uB2EC\uD588\uC2B5\uB2C8\uB2E4."
  failMessage: "\uD1B5\uD654\uC7A5\uCE58\uB294 \uC0AC\uACE0 \uC0C1\uD669\uC5D0\uC11C
    \uBA3C\uC800 \uC704\uCE58\uC640 \uC0C1\uD0DC\uB97C \uC54C\uB9B4 \uB54C \uC0AC\uC6A9\uD569\uB2C8\uB2E4."
